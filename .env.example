# ==========================================
# Dialektli Environment Configuration
# ==========================================


# ==========================================
# Database Configuration
# ==========================================
# ⚠️ FOR LOCAL DEVELOPMENT ONLY - DO NOT TOUCH PRODUCTION DATABASE ⚠️
# Use docker-compose.yml to start local PostgreSQL:
#   docker compose up -d
# Then copy these values to your .env.local file:

# Local Docker PostgreSQL (REQUIRED for development)
# ⚠️ YOU MUST COPY THESE TO .env.local FILE ⚠️
POSTGRES_URL="postgres://user:pass@localhost:5432/urbansisstionary?schema=public"
POSTGRES_URL_NON_POOLING="postgres://user:pass@localhost:5432/urbansisstionary?schema=public"

# After adding POSTGRES_URL to .env.local, initialize the database:
#   npx prisma db push --force-reset
#   npx prisma db seed (if seed data exists)

# ⚠️ IMPORTANT: These values go in .env.local, NOT here ⚠️

# Production databases (DO NOT USE IN DEVELOPMENT)
# These should ONLY be set in production environment
# VERCEL_POSTGRES_URL=""
# VERCEL_POSTGRES_URL_NON_POOLING=""
# DIGITAL_OCEAN_POSTGRES_URL=""
# DIGITAL_OCEAN_POSTGRES_URL_NON_POOLING=""

# ==========================================
# NextAuth.js v4 Configuration (Required)
# ==========================================

# Application URL (e.g., http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=""


# ==========================================
# OAuth Providers (At least one required)
# ==========================================

# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook Login - https://developers.facebook.com/
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# ==========================================
# Security (Required for production)
# ==========================================
# Google reCAPTCHA v3 - https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRETE_KEY=""

# ==========================================
# Email Configuration (Required for password reset)
# ==========================================
# Gmail App Password or SMTP credentials
NODEMAILER_EMAIL=""
NODEMAILER_PASSWORD=""

# ==========================================
# Analytics (Optional)
# ==========================================
GOOGLE_TAG_MANAGER_ID=""


# ==========================================
# Deployment (Auto-set by Vercel)
# ==========================================
VERCEL_URL=""

# ==========================================
# Feature Flags (Development/Preview)
# ==========================================
# Enable/disable features for testing in non-production environments
NEXT_PUBLIC_ENABLE_STORE=""

# ==========================================
# Future: E-commerce / Print-on-Demand (Not yet implemented)
# ==========================================
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# PRINTFUL_API_KEY=""
# PRINTIFY_API_KEY=""