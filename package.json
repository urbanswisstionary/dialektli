{
  "name": "dialektli",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "generate:sitemap": "echo 'Sitemap is generated by Next.js at build time'",
    "build": "SKIP_DB_CONNECTION=true prisma generate && SKIP_DB_CONNECTION=true npx graphql-codegen --require tsconfig-paths/register --config codegen.ts && next build",
    "start": "next start",
    "lint": "oxlint && yarn eslint --cache --cache-strategy content .",
    "lint:fix": "oxlint --fix",
    "check:types": "tsc --pretty --noEmit --incremental",
    "check:format": "oxfmt --check",
    "format": "oxfmt",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "codegen": "SKIP_DB_CONNECTION=true npx graphql-codegen --require tsconfig-paths/register --config codegen.ts"
  },
