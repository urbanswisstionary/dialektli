# adjust this file to your needs
use_fnm() {
  if ! hash fnm 2>/dev/null; then
    echo "fnm not found. Install it: https://github.com/Schniz/fnm" >&2
    return 1
  fi
  eval "$(fnm env)"
  fnm use --install-if-missing
}
watch_file .nvmrc
watch_file .node-version
if [ -f .nvmrc ] || [ -f .node-version ]; then
  use_fnm
fi

# additionaly load env vars from .env.local files
watch_file .env.local
if [ -f .env.local ]; then

  set -o allexport
  source .env.local
  set +o allexport
fi
